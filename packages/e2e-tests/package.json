{
  "name": "@lasl/e2e-tests",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "biome lint tests utils",
    "lint:fix": "biome lint --write tests utils",
    "format": "biome lint tests utils",
    "format:fix": "biome format --write tests utils",
    "check:ci": "biome check tests utils",
    "check:fix": "biome check --write tests utils",
    "check:types": "tsc",
    "test": "doppler run -- playwright test",
    "test:ui": "doppler run -- playwright test --ui",
    "test:headed": "doppler run -- playwright test --headed",
    "test:debug": "doppler run -- playwright test --debug",
    "test:report": "doppler run -- playwright show-report"
  },
  "devDependencies": {
    "@lasl/app-contracts": "workspace:*",
    "@playwright/test": "^1.59.1",
    "dotenv": "^17.4.2",
    "http-status-codes": "^2.3.0"
  }
}